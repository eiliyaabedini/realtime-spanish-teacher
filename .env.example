# --- Supabase (auto-injected when created via Vercel Marketplace; `vercel env pull`) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Postgres connection for Drizzle — use the TRANSACTION POOLER url (port 6543).
# Supabase dashboard → Connect → Transaction pooler.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# --- App secrets ---
# Encrypts user-provided OpenAI API keys at rest. Generate: openssl rand -base64 32
APP_SECRET=

# Optional shared OpenAI key — users without their own key in Settings use this one.
# Leave empty to require every user to bring their own key.
OPENAI_API_KEY=

# --- Realtime model (defaults shown) ---
REALTIME_MODEL=gpt-realtime-2
